# ═══════════════════════════════════════════════════════════════
# AmeriLend Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Core (REQUIRED) ──────────────────────────────────────────
# PostgreSQL connection string (Supabase, Railway, Neon, or local)
DATABASE_URL=postgresql://user:password@localhost:5432/amerilend

# JWT secret — minimum 32 characters, generate with: openssl rand -base64 48
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# Application identity
VITE_APP_ID=amerilend
VITE_APP_TITLE=AmeriLend
VITE_APP_LOGO=/logo.jpg

# Public URL of the deployed app (used for CORS, emails, callbacks)
VITE_APP_URL=https://amerilendloan.com

# ── OAuth ────────────────────────────────────────────────────
OAUTH_SERVER_URL=https://auth.yourdomain.com
VITE_OAUTH_PORTAL_URL=https://auth.yourdomain.com
OWNER_OPEN_ID=your-admin-open-id

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
VITE_GITHUB_CLIENT_ID=your_github_client_id

# Microsoft OAuth (https://portal.azure.com/)
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
VITE_MICROSOFT_CLIENT_ID=your_microsoft_client_id

# ── Storage (Manus Built-in Forge) ──────────────────────────
BUILT_IN_FORGE_API_URL=https://api.forge.yourdomain.com
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# ── Encryption (REQUIRED for bank account data) ─────────────
# Minimum 32 characters — generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-encryption-key-at-least-32-characters-long

# ── Payments: Stripe ─────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Payments: Cryptocurrency ─────────────────────────────────
# Get these from https://commerce.coinbase.com/
COINBASE_COMMERCE_API_KEY=your_coinbase_api_key
COINBASE_COMMERCE_WEBHOOK_SECRET=your_webhook_secret
CRYPTO_PAYMENT_ENVIRONMENT=sandbox  # Options: sandbox, production

# ── Email: SendGrid (REQUIRED for notifications) ────────────
# Get API key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_VERIFIED_EMAIL=noreply@amerilendloan.com
EMAIL_TEST_MODE=false  # Set to "true" to log emails instead of sending

# ── Email: SMTP (alternative to SendGrid) ───────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@amerilendloan.com

# ── SMS: Twilio (REQUIRED for OTP and 2FA) ──────────────────
# Get credentials from https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── AI: OpenAI (REQUIRED for AI support features) ───────────
# Get API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# ── Supabase (optional — only if using Supabase auth/storage)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Admin ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@amerilendloan.com

# ── CORS (optional — comma-separated additional origins) ─────
# ALLOWED_ORIGINS=https://custom-domain.com,https://staging.amerilendloan.com

# ── Redis (optional — enables distributed rate limiting) ─────
# REDIS_URL=redis://localhost:6379

# ── Database SSL (optional — overrides auto-detection) ───────
# DB_SSL_REJECT_UNAUTHORIZED=false

# ── Monitoring (optional) ───────────────────────────────────
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ── Analytics (optional) ────────────────────────────────────
# VITE_ANALYTICS_ENDPOINT=https://your-analytics.com
# VITE_ANALYTICS_WEBSITE_ID=your-website-id

# ── Application Environment ─────────────────────────────────
NODE_ENV=development  # Options: development, production
PORT=5000
